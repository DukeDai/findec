DATABASE_URL=file:./prisma/dev.db
WS_PORT=3001
NEXT_PUBLIC_WS_URL=http://localhost:3001

# Data Sources Configuration
# Comma-separated list of data sources in priority order (yahoo, finnhub, polygon)
# Each source is tried in order; failed sources are skipped via circuit breaker
DATA_SOURCES=yahoo,finnhub

# Number of consecutive failures before circuit breaker opens a source (default: 3)
DATA_SOURCE_CIRCUIT_BREAKER_THRESHOLD=3

# Enable mock data mode for development (default: false)
DATA_SOURCE_MOCK_MODE=false

# Fall back to mock data when all real sources fail (default: true)
DATA_SOURCE_FALLBACK_TO_MOCK=true

# Finnhub API key (optional - get from https://finnhub.io)
FINNHUB_API_KEY=

# Polygon.io API key (optional - get from https://polygon.io)
POLYGON_API_KEY=
