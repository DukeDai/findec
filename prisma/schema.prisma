generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Stock {
  symbol    String   @id
  name      String?
  exchange  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  history   HistoricalData[]
}

model HistoricalData {
  id          String   @id @default(uuid())
  stockSymbol String
  stock       Stock    @relation(fields: [stockSymbol], references: [symbol])
  date        DateTime
  open        Float
  high        Float
  low         Float
  close       Float
  volume      BigInt
  createdAt   DateTime @default(now())

  @@unique([stockSymbol, date])
}

model UserConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model FactorStrategy {
  id          String      @id @default(uuid())
  name        String
  description String?
  rules       FactorRule[]
  results     ScreeningResult[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model FactorRule {
  id              String         @id @default(uuid())
  strategy        FactorStrategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)
  strategyId      String
  field           String
  operator        String
  value           Float
  weight          Float          @default(1.0)
  createdAt       DateTime       @default(now())
}

model ScreeningResult {
  id          String        @id @default(uuid())
  strategy    FactorStrategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)
  strategyId  String
  symbol      String
  score       Float
  details     String?
  screenedAt  DateTime      @default(now())
}

model BacktestPlan {
  id            String          @id @default(uuid())
  name          String
  symbols       String
  startDate     DateTime
  endDate       DateTime
  initialCapital Float
  trades        BacktestTrade[]
  totalReturn   Float?
  sharpeRatio   Float?
  maxDrawdown  Float?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model BacktestTrade {
  id          String      @id @default(uuid())
  plan        BacktestPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  planId      String
  symbol      String
  type        String
  quantity    Float
  price       Float
  date        DateTime
  createdAt   DateTime    @default(now())
}

model Alert {
  id          String   @id @default(uuid())
  symbol      String
  condition   String
  targetValue Float?
  message     String?
  isActive    Boolean  @default(true)
  triggeredAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  type        String   @default("price")  // 'price' | 'indicator' | 'factor' | 'risk'
  metric      String?  // specific metric name
  broadcast   Boolean  @default(false)    // whether pushed via WebSocket
}

model Portfolio {
  id            String       @id @default(uuid())
  name          String
  description   String?
  positions     Position[]
  transactions  Transaction[]
  totalValue    Float        @default(0)
  totalCost     Float        @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Position {
  id          String     @id @default(uuid())
  portfolio   Portfolio  @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  portfolioId String
  symbol      String
  quantity    Float
  avgCost     Float
  currentPrice Float     @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Transaction {
  id          String     @id @default(uuid())
  portfolio   Portfolio  @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  portfolioId String
  symbol      String
  type        String
  quantity    Float
  price       Float
  total       Float
  date        DateTime
  createdAt   DateTime   @default(now())
}

// Data source metadata - track where each data point came from
model DataSourceMeta {
  id              String   @id @default(uuid())
  symbol          String
  date            DateTime
  source          String   // 'yahoo' | 'mock' | 'cache'
  sourceTimestamp DateTime
  createdAt       DateTime @default(now())

  @@unique([symbol, date])
  @@index([symbol])
  @@index([date])
}

// Factor historical values - store daily factor calculations
model FactorHistory {
  id        String   @id @default(uuid())
  factorId  String
  symbol    String
  date      DateTime
  value     Float
  rank      Float?
  zscore    Float?
  createdAt DateTime @default(now())

  @@unique([factorId, symbol, date])
  @@index([factorId])
  @@index([symbol])
  @@index([date])
}

// Portfolio-level backtest plan (extended from existing BacktestPlan)
model PortfolioBacktestPlan {
  id             String   @id @default(uuid())
  name           String
  symbols        String   // JSON array: ["AAPL", "MSFT"]
  allocation     String   // JSON object: {"AAPL": 0.5, "MSFT": 0.5}
  strategies     String   // JSON array of strategy configs
  costModel      String   @default("{}") // JSON object: commission, slippage config
  initialCapital Float
  startDate      DateTime
  endDate        DateTime
  status         String   @default("pending") // 'pending' | 'running' | 'completed' | 'failed'

  // Rebalancing settings
  rebalance          String  @default("monthly") // 'daily' | 'weekly' | 'monthly' | 'none'
  rebalanceThreshold Float?

  // Portfolio-level metrics
  portfolioReturn     Float?
  portfolioSharpe     Float?
  portfolioSortino    Float?
  portfolioCalmar     Float?
  portfolioMaxDrawdown Float?
  portfolioVolatility Float?
  portfolioVaR95     Float?

  // Detailed results (JSON strings)
  equityCurve   String?  // JSON array of {date, value}
  riskMetrics   String?  // JSON object with risk breakdown
  tradeLog      String?  // JSON array of all trades

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Risk alert log
model RiskAlertLog {
  id          String   @id @default(uuid())
  portfolioId String
  type        String   // 'drawdown' | 'concentration' | 'volatility' | 'correlation'
  severity    String   // 'warning' | 'critical'
  message     String
  current     Float
  threshold   Float
  triggeredAt DateTime
  createdAt   DateTime @default(now())

  @@index([portfolioId])
  @@index([triggeredAt])
}

// Local data cache for downloaded historical data
model LocalDataCache {
  id        String   @id @default(uuid())
  symbol    String
  range     String
  fetchedAt DateTime @default(now())
  dataHash  String

  @@unique([symbol, range])
}

// Stock name cache for Chinese name search support
model StockNameCache {
  id        String   @id @default(uuid())
  symbol    String   @unique
  name      String              // English name
  nameZh    String?             // Chinese name (optional)
  exchange  String?
  type      String?
  cachedAt  DateTime @default(now())

  @@index([nameZh])
  @@index([cachedAt])
}

// Custom user-defined trading strategies
model CustomStrategy {
  id          String   @id @default(uuid())
  name        String
  description String?
  rules       Json     // Serialized rule tree
  actions     Json     // Serialized action config
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
